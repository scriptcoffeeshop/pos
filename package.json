{
  "name": "script-coffee-pos",
  "private": true,
  "version": "0.1.0",
  "description": "Script Coffee 門市 POS、線上訂單中樞與區域網路列印 POC。",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "vue-tsc -b",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "guardrails": "python3 scripts/check_frontend_guardrails.py",
    "check:backend": "cd supabase/functions/pos-api && deno check index.ts",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "tablet:url": "bash scripts/show_tablet_url.sh",
    "cap:sync": "npm run build && cap sync android",
    "apk:debug": "bash scripts/build_debug_apk.sh",
    "apk:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "apk:install:fresh": "adb uninstall com.scriptcoffeeshop.pos || true && adb install android/app/build/outputs/apk/debug/app-debug.apk",
    "apk:open": "open android/app/build/outputs/apk/debug",
    "supabase:db:push": "bash scripts/supabase_db_push.sh",
    "supabase:functions:deploy": "bash scripts/supabase_deploy.sh",
    "pages:check": "bash scripts/check_pages_domain.sh",
    "pages:enable-https": "bash scripts/check_pages_domain.sh --enable-https",
    "deploy": "npm run supabase:db:push && npm run supabase:functions:deploy",
    "ci-local": "npm run guardrails && npm run typecheck && npm run lint && npm run check:backend && npm run build"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@supabase/supabase-js": "^2.105.3",
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.19.25",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.10",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.7"
  }
}
